# ============================================================================
# PLAYO FRONTEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in real values for your environment
# Frontend runs on http://localhost:5173 during development
# ============================================================================

# Backend API Gateway URL
VITE_BACKEND_URL=http://localhost:8040

# Application Environment (development|staging|production)
VITE_ENV=development

# Mappls API Key (for location/maps features)
VITE_MAPPLS_KEY=YOUR_MAPPLS_KEY_HERE

# JWT Secret (should match backend configuration)
VITE_JWT_SECRET=your_super_secret_key_that_is_at_least_256_bits_long