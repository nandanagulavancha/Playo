# ============================================================================
# PLAYO BACKEND SERVICES - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in real values for your environment
# This file is used by docker-compose.yml and all services via spring-dotenv
#
# WARNING: Never commit real credentials to git. Use .env locally only.
# For production, set variables in your deployment environment.
# ============================================================================

# ============================================================================
# SHARED INFRASTRUCTURE (Used by multiple services)
# ============================================================================

# Database (PostgreSQL)
DB_HOST=postgres
DB_NAME=admin
DB_USER=admin
DB_PASSWORD=admin
DB_SSL_MODE=disable

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=admin

# Cloudinary (Image Storage)
CLOUDINARY_NAME=YOUR_CLOUDINARY_NAME
CLOUDINARY_API=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_SECRET=YOUR_CLOUDINARY_SECRET_KEY

# ============================================================================
# EUREKA SERVER
# ============================================================================

EUREKA_SERVER_PORT=8761
EUREKA_HOSTNAME=eureka-server

# ============================================================================
# AUTH SERVER (Port 8081)
# ============================================================================

AUTH_SERVER_PORT=8081
AUTH_SERVER_NAME=auth-server
EUREKA_AUTH_SERVER_URL=http://eureka-server:8761/eureka
EUREKA_AUTH_HOSTNAME=auth-server

# Admin Account Seeding (for Auth Server initialization)
APP_ADMIN_EMAIL=admin@playo.com
APP_ADMIN_PASSWORD=admin123
APP_ADMIN_NAME=Playo Admin
APP_ADMIN_PHONE=9999999999

# Email Configuration (Password Reset Feature)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@playo.com

# Frontend URL (for reset links in emails)
APP_FRONTEND_URL=http://localhost:5173

# Password Reset Token Settings
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# ============================================================================
# ADMIN SERVICE (Port 8030)
# ============================================================================

ADMIN_SERVICE_PORT=8030
ADMIN_SERVICE_NAME=admin-service
EUREKA_ADMIN_SERVER_URL=http://eureka-server:8761/eureka
EUREKA_ADMIN_HOSTNAME=admin-service

# ============================================================================
# OWNER SERVICE (Port 8031)
# ============================================================================

OWNER_SERVICE_PORT=8031
OWNER_SERVICE_NAME=owner-service
EUREKA_OWNER_SERVER_URL=http://eureka-server:8761/eureka
EUREKA_OWNER_HOSTNAME=owner-service

# ============================================================================
# API GATEWAY (Port 8040)
# ============================================================================

API_GATEWAY_PORT=8040
SPRING_PROFILES_ACTIVE=docker

# CORS Configuration (semicolon-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# OPTIONAL: LOGGING CONFIGURATION
# ============================================================================

# Uncomment to enable debug logging
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_PLAYO=DEBUG
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG

# ============================================================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================================================

# JWT Token Settings (if needed)
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRATION_MS=86400000

# Database Connection Pool Settings
# DB_POOL_SIZE=10
# DB_MAX_LIFETIME=600000
